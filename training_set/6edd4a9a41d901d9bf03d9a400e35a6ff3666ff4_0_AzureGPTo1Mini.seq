    ".\n-",
    " On",
    " medium",
    " devices",
    " (",
    "\u2265",
    "768",
    "px",
    "),",
    " the",
    " first",
    " column",
    " spans",
    " ",
    "8",
    " columns",
    ",",
    " and",
    " the",
    " second",
    " spans",
    " ",
    "4",
    " columns",
    ".\n\n---\n\n##",
    " ",
    "3",
    ".",
