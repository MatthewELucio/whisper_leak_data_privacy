    " on",
    " external",
    " servers",
    ".\n  ",
    " -",
    " **",
    "Customization",
    ":**",
    " Limited",
    " unless",
    " you",
    " override",
    " styles",
    ".\n\n2",
    ".",
    " **",
    "Downloading",
    " Bootstrap",
    ":",
    "**\n\n  ",
    " Download",
    " Bootstrap",
    "\u2019s",
    " source",
    " files",
    " from",
    " the",
    " [",
    "official",
    " website",
    "](",
    "https",
    "://",
    "get",
    "bootstrap",
    ".com",
    "/",
    ").",
    " Extract",
    " the",
    " files",
    " and",
    " include",
    " them",
    " in",
    " your",
    " project",
    " directory",
    ".\n\n  ",
    " ```",
    "html",
    "\n  ",
    " <",
    "link",
    " rel",
    "=\"",
    "stylesheet",
    "\"",
    " href",
    "=\"",
    "path",
    "/to",
    "/bootstrap",
    ".min",
    ".css",
    "\">\n  ",
    " ...\n  ",
    " <",
    "script",
    " src",
    "=\"",
    "path",
    "/to",
    "/bootstrap",
    ".bundle",
    ".min",
    ".js",
    "\"></",
    "script",
    ">\n  ",
    " ``",
    "`\n\n  ",
    " **",
    "Pros",
    ":",
    "**\n  ",
    " -",
    " **",
    "Offline",
    " Access",
    ":**",
    " No",
    " dependency",
    " on",
    " external",
    " CD",
    "Ns",
    ".\n  ",
    " -",
    " **",
    "Customization",
    ":**",
    " Eas",
    "ier",
    " to",
    " modify",
    " and",
    " integrate",
    " into",
    " build",
    " processes",
    ".\n\n  ",
    " **",
    "Cons",
    ":",
    "**\n  ",
    " -",
    " **",
    "Setup",
    " Time",
    ":**",
    " Requires",
    " manual",
    " downloading",
    " and",
    " linking",
    ".\n  ",
    " -",
    " **",
    "File",
    " Size",
    ":**",
    " Adds",
    " to",
    " your",
    " project's",
    " size",
    ".\n\n3",
    ".",
    " **",
    "Using",
    " Package",
    " Managers",
    " (",
    "e",
    ".g",
    ".,",
    " npm",
    ",",
    " Yarn",
    "):",
    "**\n\n  ",
    " If",
    " you're",
    " using",
    " a",
    " Java",
    "Script",
    " package",
    " manager",
    ",",
    " you",
    " can",
    " install",
    " Bootstrap",
    " via",
    " npm",
    " or",
    " Yarn",
    ".\n\n  ",
    " ```",
    "bash",
    "\n  ",
    " #",
    " Using",
    " npm",
    "\n  ",
    " npm",
    " install",
    " bootstrap",
    "\n\n  ",
    " #",
    " Using",
    " Yarn",
    "\n  ",
    " yarn",
    " add",
    " bootstrap",
    "\n  ",
    " ``",
    "`\n\n  ",
    " **",
    "Pros",
    ":",
    "**\n  ",
    " -",
    " **",
    "Integration",
    ":**",
    " Easy",
    " integration",
    " with",
    " modern",
    " build",
    " tools",
    " like",
    " Web",
    "pack",
    ",",
    " Parcel",
    ",",
    " etc",
    ".\n  ",
    " -",
    " **",
    "Version",
    " Control",
    ":**",
    " Simpl",
    "ifies",
    " managing",
    " and",
    " updating",
    " Bootstrap",
    " versions",
    ".\n\n  ",
    " **",
    "Cons",
    ":",
    "**\n  ",
    " -",
    " **",
    "Complex",
    "ity",
    ":**",
    " Requires",
    " familiarity",
    " with",
    " package",
    " managers",
    " and",
    " build",
    " tools",
    ".\n\n###",
    " **",
    "b",
    ".",
    " Quick",
    " Start",
    " with",
    " Bootstrap",
    "**\n\nHere",
    "\u2019s",
    " a",
    " simple",
    " HTML",
    " template",
    " incorporating",
    " Bootstrap",
    " via",
    " CDN",
    ":\n\n```",
    "html",
    "\n<!",
    "DOCTYPE",
    " html",
    ">\n<html",
    " lang",
    "=\"",
    "en",
    "\">\n<head",
    ">\n ",
    " <",
    "meta",
    " charset",
    "=\"",
    "UTF",
    "-",
    "8",
    "\">\n ",
