    ">\n</",
    "body",
    ">\n</",
    "html",
    ">\n``",
    "`\n\n---\n\n##",
    " ",
    "2",
    ".",
    " **",
    "Understanding",
    " Bootstrap",
    "\u2019s",
    " Grid",
    " System",
    "**\n\nBootstrap",
    "\u2019s",
    " grid",
    " system",
    " is",
    " the",
    " backbone",
    " of",
    " its",
    " responsive",
    " layout",
    ".",
    " It",
    " uses",
    " a",
    " series",
    " of",
    " containers",
    ",",
    " rows",
    ",",
    " and",
    " columns",
    " to",
    " layout",
    " and",
    " align",
    " content",
    ".\n\n###",
    " **",
    "a",
    ".",
    " Containers",
    "**\n\nContainers",
    " are",
    " the",
    " most",
    " basic",
    " layout",
    " element",
    " in",
    " Bootstrap",
    " and",
    " are",
    " required",
    " when",
    " using",
    " the",
    " grid",
    " system",
    ".\n\n-",
    " **",
    "`.",
    "container",
    "`",
    "**",
    ":",
    " Fixed",
    "-width",
    " container",
    ".\n-",
    " **",
    "`.",
    "container",
    "-fluid",
    "`",
    "**",
    ":",
    " Full",
    "-width",
    " container",
    ",",
    " spanning",
    " the",
    " entire",
    " width",
    " of",
    " the",
    " viewport",
    ".\n\n```",
    "html",
    "\n<div",
    " class",
    "=\"",
    "container",
    "\">\n ",
    " <!--",
    " Content",
    " here",
    " -->\n</",
    "div",
    ">\n``",
    "`\n\n###",
    " **",
    "b",
    ".",
    " Rows",
    " and",
    " Columns",
    "**\n\nRows",
    " are",
    " horizontal",
    " groups",
    " of",
    " columns",
    " that",
    " ensure",
    " your",
    " columns",
    " are",
    " properly",
    " aligned",
    ".",
    " Columns",
    " are",
    " used",
    " to",
    " create",
    " the",
    " actual",
    " layout",
    ".\n\n```",
    "html",
    "\n<div",
    " class",
    "=\"",
    "container",
    "\">\n ",
    " <",
    "div",
    " class",
    "=\"",
    "row",
    "\">\n   ",
    " <",
    "div",
    " class",
    "=\"",
    "col",
    "-md",
    "-",
    "6",
    "\">\n     ",
    " <!--",
    " Column",
    " ",
    "1",
    " -->\n   ",
    " </",
    "div",
    ">\n   ",
    " <",
    "div",
    " class",
    "=\"",
    "col",
    "-md",
    "-",
    "6",
    "\">\n     ",
    " <!--",
    " Column",
    " ",
    "2",
    " -->\n   ",
    " </",
    "div",
    ">\n ",
    " </",
    "div",
    ">\n</",
    "div",
    ">\n``",
    "`\n\n**",
    "Key",
    " Points",
    ":",
    "**\n\n-",
    " **",
    "12",
    "-",
    "Column",
    " Layout",
    ":**",
    " Bootstrap",
    "\u2019s",
    " grid",
    " divides",
    " the",
    " page",
    " into",
    " ",
    "12",
    " columns",
    ".",
    " You",
    " can",
    " adjust",
    " the",
    " width",
    " of",
    " each",
    " column",
    " by",
    " specifying",
    " how",
    " many",
    " of",
    " the",
    " ",
    "12",
    " columns",
    " it",
    " should",
    " span",
    ".\n-",
    " **",
    "Responsive",
    " Break",
    "points",
    ":**",
    " Classes",
    " like",
    " `.",
    "col",
    "-sm",
    "-",
    "`,",
    " `.",
    "col",
    "-md",
    "-",
    "`,",
    " `.",
    "col",
    "-lg",
    "-",
    "`,",
    " `.",
    "col",
    "-xl",
    "-",
    "`,",
    " and",
    " `.",
    "col",
    "-",
    "xx",
    "l",
    "-",
    "`",
    " allow",
    " you",
    " to",
    " control",
    " column",
    " behavior",
    " at",
    " different",
    " screen",
    " sizes",
    ".\n\n###",
    " **",
    "c",
    ".",
    " Responsive",
    " Grid",
    " Example",
    "**\n\n```",
    "html",
    "\n<div",
    " class",
    "=\"",
    "container",
    "\">\n ",
    " <",
    "div",
    " class",
    "=\"",
    "row",
    "\">\n   ",
    " <",
    "div",
    " class",
    "=\"",
    "col",
    "-",
    "12",
    " col",
    "-md",
    "-",
    "8",
    "\">",
    ".",
    "col",
    "-",
    "12",
    " .",
    "col",
    "-md",
    "-",
    "8",
    "</",
    "div",
    ">\n   ",
    " <",
    "div",
    " class",
    "=\"",
    "col",
    "-",
    "6",
    " col",
    "-md",
    "-",
    "4",
    "\">",
    ".",
    "col",
    "-",
    "6",
    " .",
    "col",
    "-md",
    "-",
    "4",
    "</",
    "div",
    ">\n ",
    " </",
    "div",
    ">\n</",
    "div",
    ">\n``",
    "`\n\n-",
    " On",
    " extra",
    " small",
    " devices",
    " (",
    "\u2264",
    "576",
    "px",
    "),",
    " the",
    " first",
    " column",
    " spans",
    " ",
    "12",
    " columns",
    " (",
