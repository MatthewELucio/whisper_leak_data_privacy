    " horizontal",
    " group",
    " for",
    " columns",
    ".\n ",
    " -",
    " Ens",
    "ures",
    " proper",
    " alignment",
    " and",
    " spacing",
    ".\n\n-",
    " **",
    "Columns",
    " (`",
    ".",
    "col",
    "-",
    "`",
    " classes",
    "):",
    "**\n ",
    " -",
    " Defines",
    " the",
    " width",
    " of",
    " the",
    " content",
    ".\n ",
    " -",
    " Bootstrap",
    "'s",
