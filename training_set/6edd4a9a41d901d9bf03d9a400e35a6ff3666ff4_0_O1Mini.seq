    "html",
    "\n<head",
    ">\n ",
    " <!--",
    " Bootstrap",
    " CSS",
    " -->\n ",
    " <",
    "link",
    " href",
    "=\"",
    "https",
    "://",
    "cdn",
    ".jsdelivr",
