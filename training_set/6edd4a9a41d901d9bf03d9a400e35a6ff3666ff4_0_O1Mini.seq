    "stylesheet",
    "\">\n</",
    "head",
    ">\n``",
    "`\n\n**",
    "Example",
    " (",
    "custom",
    ".css",
    "):",
    "**\n\n```",
    "css",
    "\n/*",
    " Change",
    " primary",
    " button",
    " color",
    " */\n.btn",
    "-primary",
    " {\n ",
    " background",
    "-color",
    ":",
    " #",
    "ff",
    "573",
    "3",
    ";\n ",
    " border",
    "-color",
    ":",
    " #",
    "ff",
    "573",
    "3",
    ";\n}\n\n.nav",
    "bar",
    " {\n ",
