    " columns",
    " an",
    " element",
    " should",
    " span",
    ".\n\n**",
    "Responsive",
    " Break",
    "points",
    ":",
    "**\n\n-",
    " **",
    "Extra",
    " small",
    " (`",
    "xs",
    "`",
